# Sonovera frontend — API base URL (no trailing slash).
#
# Local dev (npm run dev): leave empty or comment out — Vite proxies /api → http://localhost:8000
#
# Production / Vercel: set to your deployed backend origin (must expose POST /compare with CORS).
#   • Local build: put the value in this file, then npm run build
#   • Vercel: Root Directory = src/frontend (this folder). Then Project → Settings →
#     Environment Variables → VITE_API_BASE (Production + Preview)
#
# VITE_API_BASE=https://api.yourdomain.com

VITE_API_BASE=
